) %>% as.data.frame()
salmon.data %>% summary
# remove weight outliers
salmon.data <- salmon.data[salmon.data$weight < 50 & salmon.data$length > 50, ]
# regular plot =================================================================
ggplot(data = salmon.data[salmon.data$sea.age > 2, ],
aes(x= length, y = weight)) +
geom_point() +
